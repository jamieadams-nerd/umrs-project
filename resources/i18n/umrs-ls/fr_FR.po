# TRANSLATOR: Displayed in the access-denied section footer of directory listings.
# No standalone corpus match for "access denied" in any GNU corpus file.
# "accès refusé" is the standard francophone Unix/Linux term, widely attested in
# POSIX documentation, ANSSI guidance, and OTAN/NATO francophone material.
# Identical to fr_CA — no metropolitan/Canadian difference for this phrase.
#. Translate the static label, then append the count in parentheses.
#: components/rusty-gadgets/umrs-ls/src/main.rs:175
msgid "access denied"
msgstr "accès refusé"

# TRANSLATOR: Column header for POSIX file permission bits (rwxrwxrwx / octal mode).
# No standalone column-header match for "MODE" in the corpus.
# coreutils (fr) consistently renders permission-related operations using "droits"
# throughout (e.g., "modification des droits", "impossible de modifier les droits").
# "DROITS" is therefore corpus-informed. Identical to fr_CA.
# 6 characters — within the ≤8 target for column brevity.
#. Wrap translations in Cow::Owned
#: components/rusty-gadgets/umrs-ls/src/main.rs:257
msgid "MODE"
msgstr "DROITS"

# TRANSLATOR: Column header for SELinux security marking / classification marking.
# No match found in any GNU corpus file. "MARQUAGE" is the established
# francophone technical term for security marking in OTAN/NATO and ANSSI contexts
# (e.g., "marquage de sécurité", "marquage de classification").
# Preferred over "étiquette" (label) here as this column reflects the human-readable
# marking string, not the raw SELinux label. UMRS decision; identical to fr_CA.
# 8 characters — at the ≤8 target limit.
#: components/rusty-gadgets/umrs-ls/src/main.rs:258
msgid "MARKING"
msgstr "MARQUAGE"

# TRANSLATOR: Column header for file owner UID and GID, displayed as "user:group".
# Corpus match (coreutils, chown.c): msgid "[OWNER][:[GROUP]]" → msgstr "[PROPRIO][:[GROUPE]]"
# This is the GNU Translation Project's standard French (not a Canadian regionalism);
# applies equally to fr_FR. Adapted to column-header style: "PROPRIO:GROUPE".
# 13 characters — slightly over ≤8 target, but inherent to the two-field format.
#: components/rusty-gadgets/umrs-ls/src/main.rs:259
msgid "OWNER:GROUP"
msgstr "PROPRIO:GROUPE"

# TRANSLATOR: Column header for file size in bytes.
# Corpus match (tar, tests/genfile.c): msgid "SIZE" → msgstr "TAILLE"
# Also attested in coreutils: msgid "Size" → msgstr "Taille".
# "TAILLE" is the unambiguous corpus-mandated translation. Identical to fr_CA.
# 6 characters — within the ≤8 target.
#: components/rusty-gadgets/umrs-ls/src/main.rs:260
msgid "SIZE"
msgstr "TAILLE"

# TRANSLATOR: Column header for file last-modification timestamp (mtime).
# No exact corpus match for "MODIFIED". The standard francophone term for
# last-modification state in POSIX and ANSSI documentation is "MODIFIÉ"
# (past participle). Identical to fr_CA. UMRS decision.
# 7 characters — within the ≤8 target.
#: components/rusty-gadgets/umrs-ls/src/main.rs:261
msgid "MODIFIED"
msgstr "MODIFIÉ"

# TRANSLATOR: Column header for the file or directory name.
# Corpus match (coreutils, who.c): msgid "NAME" → msgstr "NOM"
# Confirmed as exact standalone match. Identical to fr_CA.
# 3 characters — well within the ≤8 target.
#: components/rusty-gadgets/umrs-ls/src/main.rs:262
msgid "NAME"
msgstr "NOM"

# TRANSLATOR: Placeholder shown when file content or metadata is access-controlled
# and cannot be displayed to the current user. The angle-bracket format is preserved
# to match the source string convention (e.g., <restricted>, <restreint>).
# Corpus match (bash, builtins/common.c): msgid "restricted" → msgstr "restreint"
# Applying corpus term in angle-bracket placeholder format. Identical to fr_CA.
#: components/rusty-gadgets/umrs-ls/src/main.rs:467
msgid "<restricted>"
msgstr "<restreint>"
