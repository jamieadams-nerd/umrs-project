# TRANSLATOR: Startup banner printed when umrs-state begins execution.
# No corpus match for "Starting". "Démarrage de" is the standard francophone
# Linux/POSIX term for the startup phase of a service or tool.
# UMRS decision — recorded in vocabulary-fr_CA.md.
#: components/rusty-gadgets/umrs-state/src/main.rs:82
msgid "Starting umrs-state"
msgstr "Démarrage de umrs-state"

# TRANSLATOR: Status check label for FIPS 140-2/3 mode.
# "FIPS" is retained as the acronym — it is not translated in francophone
# technical contexts (OTAN/NATO, ANSSI). "activé" is the corpus-attested
# francophone term for "enabled" (coreutils: "activé", util-linux: "activé").
# No direct msgid match found; term informed by corpus usage.
#. Status is simple to give a message, and then true or false. The console
#. will print "Ok" or "Fail" next to it. This is not tied to keys.
#: components/rusty-gadgets/umrs-state/src/main.rs:85
msgid "FIPS is Enabled"
msgstr "FIPS est activé"

# TRANSLATOR: Status check label confirming a system purpose is recorded in the state file.
# "System Purpose" is a RHEL concept (subscription-manager); no direct corpus match.
# "Objet du système" is the RHEL francophone term used in RHEL subscription tooling.
# UMRS decision — recorded in vocabulary-fr_CA.md.
#: components/rusty-gadgets/umrs-state/src/main.rs:86
msgid "System Purpose defined in state file"
msgstr "Objet du système défini dans le fichier d'état"

# TRANSLATOR: Informational message printed when the state file does not yet exist
# and will be created on first write. Em-dash preserved from source.
# "fichier d'état" is the standard francophone term for a state/status file.
# UMRS decision — recorded in vocabulary-fr_CA.md.
#: components/rusty-gadgets/umrs-state/src/main.rs:150
msgid "State file does not exist — it will be created."
msgstr "Le fichier d'état n'existe pas — il sera créé."

# TRANSLATOR: Warning printed when the state file is absent in read-only mode
# and the tool falls back to a default state. "Avertissement" is the
# corpus-attested francophone translation of "Warning" (coreutils, bash: "avertissement").
# Em-dash preserved from source. UMRS decision for "état par défaut".
#: components/rusty-gadgets/umrs-state/src/main.rs:156
msgid "Warning: state file does not exist — using default state."
msgstr "Avertissement : le fichier d'état n'existe pas — utilisation de l'état par défaut."

# TRANSLATOR: Displayed when a state key has no value assigned.
# "(non défini)" is the standard francophone Linux/POSIX placeholder for an
# unset or absent value (cf. systemd francophone docs, ANSSI baseline guides).
# No corpus match found; UMRS decision — recorded in vocabulary-fr_CA.md.
#: components/rusty-gadgets/umrs-state/src/main.rs:168
#: components/rusty-gadgets/umrs-state/src/main.rs:172
#: components/rusty-gadgets/umrs-state/src/main.rs:176
#: components/rusty-gadgets/umrs-state/src/main.rs:180
msgid "(not set)"
msgstr "(non défini)"

# TRANSLATOR: Error message printed when the user supplies a key name that does
# not exist in the state schema. The key name is appended by the caller.
# Corpus match (findutils): msgid "unknown" → msgstr "inconnu(e)".
# Applying feminine form: "clé" (key) is feminine in French → "inconnue".
#: components/rusty-gadgets/umrs-state/src/main.rs:182
#: components/rusty-gadgets/umrs-state/src/main.rs:211
msgid "Unknown key"
msgstr "Clé inconnue"

# TRANSLATOR: Error message when a boolean state key receives a non-boolean value
# and the system falls back to false. "booléen/booléenne" is the standard
# francophone computing term for boolean (no corpus match; universally attested).
# "faux" is the standard francophone term for the boolean value false.
# UMRS decision — recorded in vocabulary-fr_CA.md.
#: components/rusty-gadgets/umrs-state/src/main.rs:205
msgid "Invalid boolean value — using false"
msgstr "Valeur booléenne invalide — utilisation de faux"
