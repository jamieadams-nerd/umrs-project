# No corpus match; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:705
#, fuzzy
msgid "{r} is older than catalog baseline ({b}) — update your kernel"
msgstr "{r} est plus ancien que la base de référence du catalogue ({b}) — mettez à jour votre noyau"

# ---------------------------------------------------------------------------
# Indicators summary format string templates
# DEVELOPER NOTE: These msgids are template strings containing {readable},
# {hardened}, {not_hardened}, and {pct} as named placeholders for runtime
# counts. The developer must refactor build_kernel_security_summary_rows()
# to use i18n::tr(template).replace("{readable}", ...) etc. See items 14–15.
# ---------------------------------------------------------------------------

# TRANSLATOR: Shown in the Kernel Security pinned summary when all readable
# indicators meet the hardened baseline. {readable} = count of readable
# indicators. The ✓ (U+2713) symbol is a literal character. "lisibles" is
# the fr_CA plural for "readable" (masculine plural — agree with "indicateurs").
# "tous durcis" = all hardened (masculine plural agreement).
# No corpus match for this phrase; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:788
#, fuzzy
msgid "{readable} readable — all hardened ✓"
msgstr "{readable} lisibles — tous durcis ✓"

# TRANSLATOR: Shown when some indicators do not meet the hardened baseline.
# {readable} = total readable count, {hardened} = hardened count,
# {not_hardened} = not-hardened count, {pct} = percentage not hardened.
# All four placeholders must appear in the French string unchanged.
# "lisibles" / "durcis" / "non durcis" are masculine plural to agree with
# "indicateurs". The ({pct}%) parenthetical is retained as-is.
# No corpus match; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:799
#, fuzzy
msgid "{readable} readable — {hardened} hardened, {not_hardened} not hardened ({pct}%)"
msgstr "{readable} lisibles — {hardened} durcis, {not_hardened} non durcis ({pct}%)"

