# ---------------------------------------------------------------------------
# Tab labels
# ---------------------------------------------------------------------------

# TRANSLATOR: Tab label. "Informations" is the standard fr_CA plural for
# system status/identity data panels. No corpus match; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:216
#: components/rusty-gadgets/umrs-uname/src/main.rs:302
msgid "OS Information"
msgstr "Informations système"

# TRANSLATOR: Tab label. "Sécurité noyau" is the standard fr_CA rendering
# of "Kernel Security" in Linux/POSIX francophone documentation.
# No corpus match; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:217
#: components/rusty-gadgets/umrs-uname/src/main.rs:303
msgid "Kernel Security"
msgstr "Sécurité noyau"

# TRANSLATOR: Tab label. "Confiance / Preuves" follows the OTAN/ANSSI
# pattern for trust and evidence chains in security assessment.
# No corpus match; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:218
#: components/rusty-gadgets/umrs-uname/src/main.rs:304
msgid "Trust / Evidence"
msgstr "Confiance / Preuves"

# ---------------------------------------------------------------------------
# Card title and detection status
# ---------------------------------------------------------------------------

# TRANSLATOR: Main card title. "Audit de détection" follows ANSSI/OTAN
# audit report terminology. "OS" retained as acronym.
#: components/rusty-gadgets/umrs-uname/src/main.rs:329
msgid "OS Detection Audit"
msgstr "Audit de détection OS"

# TRANSLATOR: Status message when the OS detection pipeline fails.
# "Échec" is corpus-attested for failure states; "pipeline" is retained
# as it is a technical term with no standard fr_CA substitute.
#: components/rusty-gadgets/umrs-uname/src/main.rs:267
#: components/rusty-gadgets/umrs-uname/src/main.rs:294
msgid "Detection pipeline failed"
msgstr "Échec du pipeline de détection"

# ---------------------------------------------------------------------------
# Detection error descriptions
# ---------------------------------------------------------------------------

# TRANSLATOR: "Verrou dur" is the ANSSI/OTAN francophone equivalent of a
# hard gate (a mandatory check that cannot be bypassed). "procfs" is a
# technical filesystem name — retained untranslated. UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:255
msgid "Hard gate: procfs is not real procfs"
msgstr "Verrou dur : procfs n'est pas le vrai procfs"

# TRANSLATOR: PID = Process Identifier. Technical term — retained.
# "cohérence" is the POSIX/Linux francophone standard for coherence checks.
#: components/rusty-gadgets/umrs-uname/src/main.rs:259
msgid "Hard gate: PID coherence broken"
msgstr "Verrou dur : incohérence de PID détectée"

# TRANSLATOR: "ancrage noyau" = kernel anchor. UMRS established term.
# "E/S" = Entrée/Sortie = I/O. Standard fr_CA abbreviation.
#: components/rusty-gadgets/umrs-uname/src/main.rs:261
msgid "Hard gate: I/O error during kernel anchor"
msgstr "Verrou dur : erreur d'E/S lors de l'ancrage noyau"

# ---------------------------------------------------------------------------
# Error state rows
# ---------------------------------------------------------------------------

#: components/rusty-gadgets/umrs-uname/src/main.rs:268
msgid "Status"
msgstr "État"

#: components/rusty-gadgets/umrs-uname/src/main.rs:271
#: components/rusty-gadgets/umrs-uname/src/main.rs:281
msgid "Reason"
msgstr "Raison"

#: components/rusty-gadgets/umrs-uname/src/main.rs:277
msgid "Trust Level"
msgstr "Niveau de confiance"

# TRANSLATOR: T0 = trust tier zero. Tier labels use the established UMRS
# numbering scheme; the en-dash and tier name are retained in structure.
#: components/rusty-gadgets/umrs-uname/src/main.rs:278
msgid "T0 — Untrusted"
msgstr "T0 — Non fiable"

#: components/rusty-gadgets/umrs-uname/src/main.rs:283
msgid "Hard gate failure aborted pipeline"
msgstr "Échec du verrou dur — pipeline interrompu"

# ---------------------------------------------------------------------------
# OS info rows
# ---------------------------------------------------------------------------

# TRANSLATOR: Shown when an expected data field is absent from the result.
# "non disponible" is the standard fr_CA form; no corpus match. UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:392
#: components/rusty-gadgets/umrs-uname/src/main.rs:429
#: components/rusty-gadgets/umrs-uname/src/main.rs:443
msgid "not available"
msgstr "non disponible"

#: components/rusty-gadgets/umrs-uname/src/main.rs:401
msgid "Platform Family"
msgstr "Famille de plateforme"

# TRANSLATOR: RPM = Red Hat Package Manager. Acronym — retained.
# "basé sur RPM" follows RHEL/Fedora francophone documentation style.
#: components/rusty-gadgets/umrs-uname/src/main.rs:402
msgid "RPM-based"
msgstr "basé sur RPM"

# TRANSLATOR: dpkg = Debian package manager. Tool name — retained.
#: components/rusty-gadgets/umrs-uname/src/main.rs:402
msgid "dpkg-based"
msgstr "basé sur dpkg"

# TRANSLATOR: pacman = Arch Linux package manager. Tool name — retained.
#: components/rusty-gadgets/umrs-uname/src/main.rs:402
msgid "pacman-based"
msgstr "basé sur pacman"

# TRANSLATOR: Shown when the OS family cannot be determined.
# "inconnu" is corpus-attested (findutils) for "unknown".
#: components/rusty-gadgets/umrs-uname/src/main.rs:402
msgid "unknown"
msgstr "inconnu"

#: components/rusty-gadgets/umrs-uname/src/main.rs:407
msgid "Platform Distro"
msgstr "Distribution"

#: components/rusty-gadgets/umrs-uname/src/main.rs:413
msgid "Platform Version"
msgstr "Version de plateforme"

#: components/rusty-gadgets/umrs-uname/src/main.rs:419
msgid "Platform Facts"
msgstr "Faits de plateforme"

# TRANSLATOR: "Sonde utilisée" — the detection probe that was used to
# identify the package substrate. "sonde" is the fr_CA term for a software
# probe/detector; no corpus match. UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:423
msgid "Probe Used"
msgstr "Sonde utilisée"

#: components/rusty-gadgets/umrs-uname/src/main.rs:428
msgid "Platform Identity"
msgstr "Identité de plateforme"

# ---------------------------------------------------------------------------
# unavailable fallback
# ---------------------------------------------------------------------------

# TRANSLATOR: Shown when OS release data or an indicator value is absent.
# "indisponible" (one word) is the fr_CA form for a resource that is
# inaccessible or could not be read. No corpus match; UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:135
#: components/rusty-gadgets/umrs-uname/src/main.rs:1189
msgid "unavailable"
msgstr "indisponible"

# ---------------------------------------------------------------------------
# Trust summary rows
# ---------------------------------------------------------------------------

# TRANSLATOR: Key column label for the label trust classification row.
# Shortened from "Confiance de l'étiquette" (25 chars) to "Confiance" (9 chars)
# to prevent the key column from jamming the value column in the TUI.
# "Confiance" alone is unambiguous in context: the value column carries
# the full classification string. UMRS decision.
# Visual check: English "Label Trust" = 11 chars; French "Confiance" = 9 chars.
#: components/rusty-gadgets/umrs-uname/src/main.rs:467
msgid "Label Trust"
msgstr "Confiance"

# TRANSLATOR: Key column label for the trust tier row.
# Shortened from "Palier de confiance" (19 chars) to "Palier" (6 chars)
# to match the English key width ("Trust Tier" = 10 chars) and prevent
# column jamming. "Palier" alone is unambiguous: the value column shows
# the full tier label (e.g., "T4 — Ancré à l'intégrité"). UMRS decision.
# Visual check: English "Trust Tier" = 10 chars; French "Palier" = 6 chars.
#: components/rusty-gadgets/umrs-uname/src/main.rs:489
msgid "Trust Tier"
msgstr "Palier"

#: components/rusty-gadgets/umrs-uname/src/main.rs:494
msgid "Description"
msgstr "Description"

# TRANSLATOR: Key column label for the downgrade reasons row.
# Shortened from "Motifs de déclassement" (22 chars) to "Motifs" (6 chars)
# to match the English key width ("Downgrade Reasons" = 17 chars) and
# prevent column jamming. "Motifs" alone is sufficient: the value column
# carries either a count or "Aucun déclassement — confiance totale maintenue".
# "déclassement" follows ANSSI terminology for a trust downgrade.
# UMRS decision.
# Visual check: English "Downgrade Reasons" = 17 chars; French "Motifs" = 6 chars.
#: components/rusty-gadgets/umrs-uname/src/main.rs:504
msgid "Downgrade Reasons"
msgstr "Motifs"

# TRANSLATOR: Positive result — no downgrade occurred; full trust was
# achieved at the current tier.
#: components/rusty-gadgets/umrs-uname/src/main.rs:505
msgid "No downgrade — full trust retained"
msgstr "Aucun déclassement — confiance totale maintenue"

#: components/rusty-gadgets/umrs-uname/src/main.rs:517
msgid "Each reason below prevented a trust tier upgrade."
msgstr "Chaque motif ci-dessous a empêché une montée en palier de confiance."

#: components/rusty-gadgets/umrs-uname/src/main.rs:536
msgid "Contradictions"
msgstr "Contradictions"

# TRANSLATOR: Positive result — no contradictions between evidence sources.
#: components/rusty-gadgets/umrs-uname/src/main.rs:537
msgid "None detected"
msgstr "Aucune détectée"

# TRANSLATOR: Explanatory note when all evidence sources agreed.
# Em-dash preserved. Typography: space before em-dash per fr_CA convention.
#: components/rusty-gadgets/umrs-uname/src/main.rs:542
msgid "All evidence sources agreed — no conflicting identity assertions detected."
msgstr "Toutes les sources de preuves concordent — aucune assertion d'identité contradictoire détectée."

# TRANSLATOR: Warning when two independent evidence sources disagree.
# Em-dash preserved. "falsification" is the ANSSI/OTAN term for tampering.
# WIDTH: 66-char limit. Both sentences fit within the limit.
#: components/rusty-gadgets/umrs-uname/src/main.rs:555
msgid ""
"Two independent sources reported conflicting values. Review each pair — this "
"may indicate tampering."
msgstr ""
"Deux sources indépendantes rapportent des valeurs contradictoires. Vérifiez "
"chaque paire — cela peut indiquer une falsification."

# TRANSLATOR: Key column label for the evidence records count row.
# Shortened from "Enregistrements de preuves" (26 chars) to "Preuves" (7 chars)
# to match the English key width ("Evidence Records" = 16 chars) and prevent
# column jamming. The value column always contains an integer count, so
# "Preuves" (evidence/proof items) is unambiguous. UMRS decision.
# Visual check: English "Evidence Records" = 16 chars; French "Preuves" = 7 chars.
#: components/rusty-gadgets/umrs-uname/src/main.rs:577
msgid "Evidence Records"
msgstr "Preuves"

# ---------------------------------------------------------------------------
# label_trust_display — trust classification strings
# ---------------------------------------------------------------------------

# TRANSLATOR: The label candidate has not been verified by any trust gate.
# "Ne pas utiliser pour la politique" is the security-domain fr_CA form for
# "do not use for policy" — "politique" here means SELinux/MLS security
# policy, not general policy. Retain the type name prefix in English as
# a type identifier. WIDTH: 66-char limit; this line is 57 chars — OK.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1405
msgid "UntrustedLabelCandidate — do not use for policy"
msgstr "UntrustedLabelCandidate — ne pas utiliser pour la politique"

# TRANSLATOR: The label is structurally well-formed (correct syntax) but
# no integrity check (ownership/digest) has been run yet.
# "valide structurellement" follows ANSSI structural validation terminology.
# WIDTH: 65 chars — OK.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1409
msgid "LabelClaim — structurally valid; integrity unconfirmed"
msgstr "LabelClaim — valide structurellement ; intégrité non confirmée"

# TRANSLATOR: Highest normal trust tier. T4 = Integrity Anchored.
# "propriété + condensé vérifiés" = ownership + digest verified.
# "condensé" is the ANSSI/ISO fr_CA term for cryptographic hash/digest.
# WIDTH: 57 chars — OK.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1413
msgid "TrustedLabel — T4: ownership + digest verified"
msgstr "TrustedLabel — T4 : propriété + condensé vérifiés"

# TRANSLATOR: T4 integrity confirmed but a contradiction was also found.
# Abbreviated to fit the column width — full detail in a secondary row.
# "Vérifié avec contradiction" is a compound finding label.
# WIDTH: 63 chars — OK.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1422
msgid "Verified w/ Contradiction — T4 integrity + conflict"
msgstr "Vérifié avec contradiction — intégrité T4 + conflit"


#: components/rusty-gadgets/umrs-uname/src/main.rs:69
msgid "T1 — Kernel Anchored"
msgstr "T1 — Ancré au noyau"

#: components/rusty-gadgets/umrs-uname/src/main.rs:70
msgid "T2 — Environment Anchored"
msgstr "T2 — Ancré à l'environnement"

#: components/rusty-gadgets/umrs-uname/src/main.rs:71
msgid "T3 — Platform Verified"
msgstr "T3 — Plateforme vérifiée"

#: components/rusty-gadgets/umrs-uname/src/main.rs:72
msgid "T4 — Integrity Anchored"
msgstr "T4 — Ancré à l'intégrité"

# TRANSLATOR: One-line description for the T0 trust tier.
#: components/rusty-gadgets/umrs-uname/src/main.rs:78
msgid "No kernel anchor established."
msgstr "Aucun ancrage noyau établi."

# TRANSLATOR: procfs = /proc filesystem. Technical name — retained.
# PROC_SUPER_MAGIC = kernel magic number constant — retained.
# "PID" = Process Identifier — retained.
#: components/rusty-gadgets/umrs-uname/src/main.rs:80
msgid "procfs verified via PROC_SUPER_MAGIC + PID coherence."
msgstr "procfs vérifié via PROC_SUPER_MAGIC + cohérence PID."

# TRANSLATOR: mountinfo = /proc/self/mountinfo (kernel file name) — retained.
# statfs = system call name — retained.
#: components/rusty-gadgets/umrs-uname/src/main.rs:83
msgid "Mount topology cross-checked (mountinfo vs statfs)."
msgstr "Topologie de montage recoupée (mountinfo vs statfs)."

# TRANSLATOR: >= 2 retained as a mathematical expression.
#: components/rusty-gadgets/umrs-uname/src/main.rs:86
msgid "Platform identity verified; >= 2 independent package facts confirmed."
msgstr "Identité de plateforme vérifiée ; >= 2 faits paquets indépendants confirmés."

# TRANSLATOR: os-release = filename — retained. "condensé installé" =
# installed digest (cryptographic hash from package database).
#: components/rusty-gadgets/umrs-uname/src/main.rs:89
msgid "os-release ownership + installed digest verified."
msgstr "Propriété de os-release + condensé installé vérifiés."

# ---------------------------------------------------------------------------
# Status bar messages
# ---------------------------------------------------------------------------

# TRANSLATOR: "Intégrité ancrée" mirrors the tier label T4. Used as
# a brief status bar confirmation.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1431
msgid "Integrity Anchored"
msgstr "Intégrité ancrée"

# TRANSLATOR: T3 tier label abbreviated for the status bar.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1434
msgid "Platform Verified"
msgstr "Plateforme vérifiée"

# TRANSLATOR: T0 status bar label with explanation suffix.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1454
msgid "Untrusted — no kernel anchor"
msgstr "Non fiable — aucun ancrage noyau"

# ---------------------------------------------------------------------------
# Kernel Security summary rows
# ---------------------------------------------------------------------------

#: components/rusty-gadgets/umrs-uname/src/main.rs:748
msgid "Kernel Version"
msgstr "Version du noyau"

# TRANSLATOR: Provenance note shown in the kernel security summary pane.
# "/proc" and "/sys" are filesystem paths — retained.
#: components/rusty-gadgets/umrs-uname/src/main.rs:755
msgid "All values below are read live from the running kernel via /proc and /sys."
msgstr "Toutes les valeurs ci-dessous sont lues en direct depuis le noyau actif via /proc et /sys."

# TRANSLATOR: Column header for the count of readable indicators.
# "Indicateurs" is the fr_CA term for posture indicators. UMRS decision.
#: components/rusty-gadgets/umrs-uname/src/main.rs:809
msgid "Indicators"
msgstr "Indicateurs"

# TRANSLATOR: Row label for indicators that could not be assessed.
#: components/rusty-gadgets/umrs-uname/src/main.rs:816
msgid "No Assessment"
msgstr "Sans évaluation"

# TRANSLATOR: Curated summary note. "durcissement" is the ANSSI fr_CA
# term for hardening. "posture de sécurité" is corpus-attested.
# WIDTH: The longest translated line is 67 chars. FLAG for developer review.
# Proposed abbreviation if needed: replace "ci-dessous" with "en rouge".
#: components/rusty-gadgets/umrs-uname/src/main.rs:831
msgid ""
"Curated indicators selected to give you the clearest view of your system's "
"security posture. Items marked in red can be hardened — see each indicator's "
"recommended setting below."
msgstr ""
"Indicateurs sélectionnés pour offrir la vue la plus claire de la posture de "
"sécurité du système. Les éléments en rouge peuvent être durcis — "
"consultez le réglage recommandé de chaque indicateur ci-dessous."

#: components/rusty-gadgets/umrs-uname/src/main.rs:685
msgid "Catalog Baseline"
msgstr "Base de référence du catalogue"

# TRANSLATOR: Positive result — running kernel matches the catalog version.
#: components/rusty-gadgets/umrs-uname/src/main.rs:693
msgid "Catalog baseline matches running kernel"
msgstr "La base de référence du catalogue correspond au noyau actif"

# TRANSLATOR: Fragment when running kernel is newer than baseline.
# Used in: "{r} <this> ({b}) — <some indicators may have changed>"
#: components/rusty-gadgets/umrs-uname/src/main.rs:686
msgid "is newer than catalog baseline"
msgstr "est plus récent que la base de référence du catalogue"

# TRANSLATOR: Fragment when running kernel is older than baseline.
#: components/rusty-gadgets/umrs-uname/src/main.rs:700
msgid "is older than catalog baseline"
msgstr "est plus ancien que la base de référence du catalogue"

# TRANSLATOR: Fragment appended after "is newer than catalog baseline".
#: components/rusty-gadgets/umrs-uname/src/main.rs:687
msgid "some indicators may have changed"
msgstr "certains indicateurs ont peut-être changé"

# TRANSLATOR: Fragment appended after "is older than catalog baseline".
# "mettez à jour votre noyau" — UMRS vocabulary; attested in vocabulary-fr_CA.md.
#: components/rusty-gadgets/umrs-uname/src/main.rs:701
msgid "update your kernel"
msgstr "mettez à jour votre noyau"

# TRANSLATOR: Label for baseline row when version cannot be parsed.
# "base de référence" = baseline (UMRS decision).
#: components/rusty-gadgets/umrs-uname/src/main.rs:679
msgid "baseline"
msgstr "base de référence"

# ---------------------------------------------------------------------------
# Kernel contradiction rows
# ---------------------------------------------------------------------------

# TRANSLATOR: Value shown when the contradiction count is zero (positive).
# "Aucune" (feminine) agrees with "Contradictions" (feminine plural).
#: components/rusty-gadgets/umrs-uname/src/main.rs:620
msgid "None"
msgstr "Aucune"

# TRANSLATOR: Count fragment. Used in: "{count} — configuration/kernel disagreements detected"
#: components/rusty-gadgets/umrs-uname/src/main.rs:625
msgid "configuration/kernel disagreements detected"
msgstr "désaccords configuration/noyau détectés"

# TRANSLATOR: Separator between two source identifiers in a contradiction row.
# Used in: "[{idx}] {source_a} vs {source_b}"
#: components/rusty-gadgets/umrs-uname/src/main.rs:567
msgid "vs"
msgstr "c."


# TRANSLATOR: Positive result — running kernel and persisted config agree.
#: components/rusty-gadgets/umrs-uname/src/main.rs:645
msgid "No disagreements between running kernel and persisted configuration."
msgstr "Aucun désaccord entre le noyau actif et la configuration persistée."

# TRANSLATOR: Warning when kernel and persisted configuration disagree.
# "dérive" = drift (ANSSI term for configuration drift). "corrections
# éphémères" = hotfixes. "au prochain redémarrage" = on reboot.
# WIDTH: lines up to 66 chars — OK.
#: components/rusty-gadgets/umrs-uname/src/main.rs:651
msgid ""
"The running kernel and persisted configuration disagree on one or more "
"settings. Drift means intended hardening is not active; hotfixes mean "
"current hardening will be lost on reboot."
msgstr ""
"Le noyau actif et la configuration persistée sont en désaccord sur un ou "
"plusieurs réglages. Une dérive signifie que le durcissement prévu n'est pas "
"actif ; des corrections éphémères signifient que le durcissement actuel "
"sera perdu au prochain redémarrage."

# ---------------------------------------------------------------------------
# indicator_group_rows — Configured: prefix
# ---------------------------------------------------------------------------

# TRANSLATOR: Label prefix for a persisted configuration value line.
# The colon is part of the msgid — preserve it.
# Usage: "Configuré : <value> (source <filepath>)"
#: components/rusty-gadgets/umrs-uname/src/main.rs:1112
msgid "Configured:"
msgstr "Configuré :"

# TRANSLATOR: Introduces the source file for a configured value.
# French word order: "source" precedes the path in the formatted string.
# Developer note: the format call becomes:
#   format!("{} {} ({} {})", tr("Configured:"), raw, tr("from"), source_file)
#: components/rusty-gadgets/umrs-uname/src/main.rs:1112
msgid "from"
msgstr "source"

# ---------------------------------------------------------------------------
# Kernel Security group titles and descriptions
# ---------------------------------------------------------------------------

# TRANSLATOR: Group title in all-caps — preserved in French as all-caps
# to maintain visual alignment with other group titles.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1021
msgid "BOOT INTEGRITY"
msgstr "INTÉGRITÉ AU DÉMARRAGE"

# TRANSLATOR: One-line group description. "état inviolable" = tamper-
# resistant state. "remplacé silencieusement" = silently replaced.
# WIDTH: 66-char limit. Longest line is 65 chars — OK.
#: components/rusty-gadgets/umrs-uname/src/main.rs:1025
msgid ""
"Verifies the kernel loaded in a tamper-resistant state and cannot be "
"silently replaced at runtime."
msgstr ""
"Vérifie que le noyau a été chargé dans un état inviolable et ne peut pas "
"être remplacé silencieusement à l'exécution."

#: components/rusty-gadgets/umrs-uname/src/main.rs:873
msgid "CRYPTOGRAPHIC POSTURE"
msgstr "POSTURE CRYPTOGRAPHIQUE"

# TRANSLATOR: "cryptographie validée par le gouvernement" = government-
# validated cryptography (FIPS context). "sourçage d'entropie" = entropy
# sourcing. "algorithmes non validés" = unvalidated algorithms.
# WIDTH: 66-char limit. Lines are within range.
#: components/rusty-gadgets/umrs-uname/src/main.rs:874
msgid ""
"Verifies government-validated cryptography and correct entropy sourcing. "
"Failures here mean sensitive operations may use unvalidated algorithms."
msgstr ""
"Vérifie la cryptographie validée par le gouvernement et le sourçage "
"d'entropie correct. Les échecs ici signifient que des opérations sensibles "
"pourraient utiliser des algorithmes non validés."

#: components/rusty-gadgets/umrs-uname/src/main.rs:887
msgid "KERNEL SELF-PROTECTION"
msgstr "AUTO-PROTECTION DU NOYAU"

# TRANSLATOR: ASLR = acronym retained. "code exploitable" = exploitable code.
# WIDTH: lines within 66-char limit.
#: components/rusty-gadgets/umrs-uname/src/main.rs:888
msgid ""
"Controls that hide kernel internals from unprivileged processes. Weak "
"settings let attackers locate exploitable code and bypass ASLR."
msgstr ""
"Contrôles qui masquent les internes du noyau aux processus sans privilèges. "
"Des réglages faibles permettent aux attaquants de localiser du code "
"exploitable et de contourner l'ASLR."

#: components/rusty-gadgets/umrs-uname/src/main.rs:902
msgid "PROCESS ISOLATION"
msgstr "ISOLATION DES PROCESSUS"

# TRANSLATOR: "vol d'identifiants" = credential theft.
# "processus frères" = sibling processes (Unix terminology).
# WIDTH: within limit.
#: components/rusty-gadgets/umrs-uname/src/main.rs:903
msgid ""
"Controls how much one process can see or interfere with another. Weak "
"settings allow credential theft across sibling processes."
msgstr ""
"Contrôles définissant ce qu'un processus peut voir ou perturber chez un "
"autre. Des réglages faibles permettent le vol d'identifiants entre processus "
"frères."

#: components/rusty-gadgets/umrs-uname/src/main.rs:913
msgid "FILESYSTEM HARDENING"
msgstr "DURCISSEMENT DU SYSTÈME DE FICHIERS"

# TRANSLATOR: "escalade de privilèges" = privilege escalation (ANSSI term).
# "liens symboliques/physiques" = symlink/hardlink. "répertoires en écriture
# pour tous" = world-writable directories.
# WIDTH: FLAG — "DURCISSEMENT DU SYSTÈME DE FICHIERS" is 38 chars as a
# group title, within the 66-char limit. Description lines are within limit.
#: components/rusty-gadgets/umrs-uname/src/main.rs:914
msgid ""
"Closes privilege escalation paths through the filesystem. Absent controls "
"allow symlink and hardlink attacks in world-writable directories."
msgstr ""
"Ferme les chemins d'escalade de privilèges dans le système de fichiers. "
"L'absence de contrôles permet les attaques par lien symbolique et physique "
"dans les répertoires en écriture pour tous."

#: components/rusty-gadgets/umrs-uname/src/main.rs:927
msgid "MODULE RESTRICTIONS"
msgstr "RESTRICTIONS DE MODULES"

# TRANSLATOR: "vecteurs d'exfiltration de données" = data exfiltration
# vectors. "vecteurs d'attaque DMA" = DMA attack vectors. USB, FireWire,
# Thunderbolt — proper nouns, retained.
# WIDTH: within limit.
#: components/rusty-gadgets/umrs-uname/src/main.rs:928
msgid ""
"Verifies high-risk kernel modules are blocked from loading. USB, FireWire, "
"and Thunderbolt are primary data exfiltration and DMA attack vectors."
msgstr ""
"Vérifie que les modules noyau à haut risque sont bloqués au chargement. "
"USB, FireWire et Thunderbolt sont les principaux vecteurs d'exfiltration de "
"données et d'attaque DMA."

#: components/rusty-gadgets/umrs-uname/src/main.rs:949
msgid "NETWORK AUDITING"
msgstr "AUDIT RÉSEAU"

# TRANSLATOR: "comptabilisation du trafic" = traffic accounting (netfilter
# connection tracking context). "reconstruction forensique" = forensic
# reconstruction. "journaux d'audit réseau" = network audit logs.
# "exfiltration" retained as internationally standardised term.
# WIDTH: within limit.
#: components/rusty-gadgets/umrs-uname/src/main.rs:950
msgid ""
"Controls that enable traffic accounting for anomaly detection and forensic "
"reconstruction. Without these, network audit logs lack the volume data "
"needed to identify exfiltration."
msgstr ""
"Contrôles qui activent la comptabilisation du trafic pour la détection "
"d'anomalies et la reconstruction forensique. Sans ceux-ci, les journaux "
"d'audit réseau manquent des données de volume nécessaires pour identifier "
"une exfiltration."

