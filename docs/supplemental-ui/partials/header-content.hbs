<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="{{{or site.url siteRootPath}}}">
        <img class="wizard-logo" src="{{{uiRootPath}}}/img/wizard-logo.png" alt="UMRS" height="32" width="32">
        <span class="site-title">UMRS</span>
        <span class="site-subtitle">High-Assurance MLS Reference System</span>
      </a>
      {{#if env.SITE_SEARCH_PROVIDER}}
      <div class="navbar-item search hide-for-print">
        <div id="search-field" class="field">
          <input id="search-input" type="text" placeholder="Search the docs"
            {{#if page.home}} autofocus{{/if}}>
        </div>
      </div>
      {{/if}}
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark theme" title="Toggle theme">&#9790;</button>
      <button class="navbar-burger" aria-controls="topbar-nav"
        aria-expanded="false" aria-label="Toggle main menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    <div id="topbar-nav" class="navbar-menu">
    </div>
  </nav>
</header>
