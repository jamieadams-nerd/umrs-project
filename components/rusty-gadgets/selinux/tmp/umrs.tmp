########################################
# Configuration types
#
# umrs_config_ro_t - baseline site configuration shipped in the
#                    package; never written at runtime.
# umrs_config_rw_t - operator-editable site overrides; written
#                    by umrs-admin group members via DAC, and (in
#                    a future actor domain) via umrs_manage_config.
########################################

type umrs_config_ro_t;
 	 	
