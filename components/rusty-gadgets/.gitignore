# components/rusty-gadgets/.gitignore

# Cargo build output
/target/

# Staging directory — ephemeral output of `cargo xtask stage`.
# Never commit. Regenerated by `make build` or `make release`.
/staging/

# SELinux policy build artifacts.
# umrs.fc is generated from umrs.fc.in by the Makefile (substitutes
# @PREFIX@); umrs.pp is the compiled policy package; tmp/ is the
# refpolicy devel scratch area. All three are regenerated by
# `make -C selinux/`.
/selinux/umrs.fc
/selinux/umrs.pp
/selinux/tmp/
