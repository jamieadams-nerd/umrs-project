{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-cleanup.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "env": {
    "PATH": "~/.local/bin:/home/jamie/.cargo/bin:/usr/local/bin:/usr/bin:/bin"
  },
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(cargo:*)",
      "Bash(cd:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo metadata:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(export:*)",
      "Bash(diff:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(gh api:*)",
      "Bash(git:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git blame:*)",
      "Bash(git ls-files:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(ls -lh:*)",
      "Bash(make:*)",
      "Bash(/media/psf/repos/umrs-project/build-tools/antora/node_modules/.bin/antora:*)",
      "Bash(mkdir:*)",
      "Bash(msgfmt:*)",
      "Bash(msginit:*)",
      "Bash(mv:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pwd:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(RAG_CHROMA_PATH=/media/psf/repos/ai-rag-vdb/chroma python3:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(rpm:*)",
      "Bash(sqlite3:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(wc:*)",
      "Bash(xtr:*)",
      "Read(*)",
      "Read(.claude/)",
      "Read(rust-gadgets/)",
      "Read(umrs-project/)",
      "Read(/home/jadams/**)",
      "Read(/media/psf/repos/ai-rag-vdb/**)",
      "Read(/media/psf/repos/umrs-project/**)",
      "Read(/tmp/**)",
      "Read(/tmp/gettext_test/**)",
      "WebFetch(domain:*)",
      "Bash(pandoc:*)",
      "WebSearch",
      "Write(logs/task-log.md)",
      "Write(.claude/references/**)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(gh:*)",
      "Bash(sha256sum:*)"
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "allowedTools": [
    "Bash(.claude/commands/*)",
    "Bash(.claude/rag/ingest.py*)",
    "Bash(.claude/rag/query.py*)"
  ]
}
